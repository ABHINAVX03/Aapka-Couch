    // Verify token against sessions table
    const tokenHash2 = hashToken(authToken)
    const { data: session, error: sessionError } = await supabaseAdmin
      .from('sessions')
      .select('user_id')
      .eq('token_hash', tokenHash2)
      .gt('expires_at', new Date().toISOString())
