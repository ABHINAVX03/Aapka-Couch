      cookieStore.delete('auth-token')
      return NextResponse.json({ error: 'Invalid or expired token' }, { status: 401 })
    }

    const body = await req.json()
    const {
      scan_date,
      weight_kg,
      body_fat_percent,
      waist_inches,
