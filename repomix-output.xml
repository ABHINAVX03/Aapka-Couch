    router.push('/login')
  }

  // ---------- RENDER STATES ----------
  if (loading) return (
    <div className="min-h-screen bg-[#0c0c10] text-white flex items-center justify-center font-mono">
      Loading AapkaCoach profile...
    </div>
  )

  // FIX: generating no longer replaces the whole page — it only disables the button
