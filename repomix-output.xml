                Continue
              </button>
            ) : (
              <button onClick={handleSubmit} className="px-8 py-3 bg-yellow-500 text-black rounded-xl font-extrabold hover:bg-yellow-400 transition-all shadow-lg shadow-yellow-500/20">
                Generate Plan
              </button>
            )}
          </div>
        </div>
      </div>

    </div>
  )
}
