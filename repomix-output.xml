            )}
          </div>

          <div className="flex gap-3">
            {step > 0 && (
              <button onClick={prevStep} disabled={loading} className="px-5 py-3 border-2 border-[#222230] text-gray-300 rounded-xl hover:bg-[#17171f] hover:text-white transition-all font-semibold">
